{
  "name": "nimiapp-tester",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "pnpm run dev:renderer",
    "dev:renderer": "vite --host 127.0.0.1 --port 1468 --strictPort",
    "dev:shell": "node scripts/dev-shell.mjs",
    "init": "nimi-app init",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "build:shell": "tauri build",
    "test": "node --test test/*.test.mjs",
    "check": "pnpm run doctor && pnpm run test && pnpm run validate",
    "pack": "pnpm run build && node scripts/pack.mjs",
    "validate": "node scripts/validate.mjs",
    "local-audit": "node scripts/local-audit.mjs",
    "doctor": "nimi-app doctor",
    "update": "nimi-app update"
  },
  "dependencies": {
    "@nimiplatform/sdk": "^0.5.15",
    "@nimiplatform/kit": "^0.1.0",
    "@tauri-apps/api": "^2.9.1",
    "i18next": "^25.8.18",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.8"
  },
  "devDependencies": {
    "@nimiplatform/app-tools": "^0.1.4",
    "@nimiplatform/nimi-coding": "0.2.5",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
